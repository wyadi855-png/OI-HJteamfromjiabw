function setLoading(id,on){const btn=document.getElementById(id);btn.disabled=on;btn.classList.toggle('loading',on);btn.querySelector('.btn-label').textContent=on?'验证中…':(id==='btn-login'?'进入系统':'创建账号');}
async function doLogin(){clearErrors();const username=document.getElementById('l-user').value.trim(),password=document.getElementById('l-pass').value;if(!username){showError('login-err','请输入用户名');return;}if(!password){showError('login-err','请输入密码');return;}setLoading('btn-login',true);try{const{createClient}=supabase,sb=createClient(SB_URL,SB_KEY),{error}=await sb.auth.signInWithPassword({email:toEmail(username),password});if(error){showError('login-err','用户名或密码错误');setLoading('btn-login',false);return;}showSuccess(username);}catch(e){showError('login-err','网络错误，请重试');setLoading('btn-login',false);}}
async function doRegister(){clearErrors();const username=document.getElementById('r-user').value.trim(),password=document.getElementById('r-pass').value,password2=document.getElementById('r-pass2').value,group_val=document.getElementById('r-group').value,group_id=group_val?parseInt(group_val):null,luogu_uid=document.getElementById('r-luogu').value.trim();if(!username||username.length<2){showError('register-err','用户名至少2位');return;}if(!/^[a-zA-Z0-9_]+$/.test(username)){showError('register-err','只能含字母、数字、下划线');return;}if(password.length<6){showError('register-err','密码至少6位');return;}if(password!==password2){showError('register-err','两次密码不一致');return;}if(!group_id){showError('register-err','请选择训练组');return;}setLoading('btn-register',true);try{const{createClient}=supabase,sb=createClient(SB_URL,SB_KEY),{error:signUpError}=await sb.auth.signUp({email:toEmail(username),password});if(signUpError){showError('register-err',signUpError.message);setLoading('btn-register',false);return;}await new Promise(r=>setTimeout(r,1200));const{error:loginError}=await sb.auth.signInWithPassword({email:toEmail(username),password});if(loginError){showError('register-err','注册成功，请手动登录');setLoading('btn-register',false);switchTab('login');return;}const{data:{user}}=await sb.auth.getUser();if(user){const{data:ex}=await sb.from('profiles').select('id').eq('id',user.id).maybeSingle();if(ex){await sb.from('profiles').update({username,group_id,luogu_uid:luogu_uid||''}).eq('id',user.id);}else{await sb.from('profiles').insert({id:user.id,username,group_id,luogu_uid:luogu_uid||''});}}showSuccess(username);}catch(e){showError('register-err','网络错误，请重试');setLoading('btn-register',false);}}
</script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</body>
