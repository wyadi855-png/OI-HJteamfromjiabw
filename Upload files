        <span id="pd-tags" class="pd-tags"></span>
      </div>
      <h2 id="pd-title" style="margin:6px 0 0"></h2>
      <div class="pd-limits">
        <span id="pd-time">⏱ 1000ms</span>
        <span id="pd-mem">💾 256MB</span>
        <a id="pd-source-link" href="#" target="_blank" style="display:none" class="pd-source-btn">🔗 原题</a>
      </div>
      <button class="modal-close" onclick="closeModal('problem-detail-modal')" style="position:absolute;top:16px;right:16px">✕</button>
    </div>
    <div class="prob-detail-body">
      <div class="prob-statement" id="pd-statement">
        <div class="prob-section-label">题目描述</div>
        <div id="pd-desc" class="prob-text"></div>
        <div class="prob-section-label" style="margin-top:16px">输入格式</div>
        <div id="pd-input-fmt" class="prob-text"></div>
        <div class="prob-section-label" style="margin-top:16px">输出格式</div>
        <div id="pd-output-fmt" class="prob-text"></div>
        <div id="pd-examples-wrap"></div>
        <div id="pd-hint-wrap"></div>
        <div id="pd-solution-wrap" style="display:none">
          <div class="prob-section-label" style="margin-top:16px;color:var(--accent2)">题解</div>
          <div id="pd-solution" class="prob-text"></div>
        </div>
      </div>
      <div class="prob-editor-panel">
        <div class="judge-toolbar">
          <select id="pd-lang" class="judge-select" onchange="onPdLangChange()">
            <option value="54">C++ 17</option>
            <option value="53">C++ 14</option>
            <option value="50">C</option>
            <option value="71">Python 3</option>
            <option value="62">Java</option>
            <option value="63">JavaScript</option>
            <option value="60">Go</option>
          </select>
          <button class="judge-btn judge-run-btn" onclick="runProblemCode()" id="pd-run-btn">▶ 提交</button>
          <button class="judge-btn" onclick="testWithSample()">🧪 测样例</button>
          <button class="judge-btn" onclick="clearPdCode()">⌫ 清空</button>
        </div>
        <div id="pd-editor" class="judge-editor" style="height:340px"></div>
        <div class="pd-io">
          <div class="pd-io-row">
            <div class="judge-io-label"><span>📥 自定义输入</span></div>
            <textarea id="pd-stdin" class="judge-io-textarea" style="height:80px" placeholder="留空则用样例输入"></textarea>
          </div>
          <div id="pd-verdict" class="judge-verdict" style="margin-top:8px"></div>
          <div class="judge-io-label" style="margin-top:8px"><span>📤 输出</span><div id="pd-stats" class="judge-stats"></div></div>
          <div id="pd-output" class="judge-output" style="min-height:80px"><div class="judge-output-placeholder">点击提交运行代码</div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- TOAST 提示 -->
<div id="toast" class="toast"></div>

<!-- NOTE DRAWER (写题解侧边抽屉) -->
<div class="drawer-overlay" id="note-drawer-overlay" onclick="closeNoteDrawer()"></div>
<div class="drawer" id="note-drawer">
  <div class="drawer-header">
    <h2 style="font-size:18px;font-weight:700">✍️ 写题解</h2>
    <button class="drawer-close" onclick="closeNoteDrawer()">✕</button>
  </div>
  <div class="form-group">
    <label>标题</label>
    <input type="text" id="note-title" placeholder="例：P3376 最大流 Dinic 详解">
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>洛谷题号</label>
      <input type="text" id="note-problem" placeholder="P????">
    </div>
    <div class="form-group">
      <label>知识点标签</label>
      <input type="text" id="note-topic" placeholder="例：网络流">
    </div>
  </div>
  <div class="form-group">
    <label>解题思路</label>
    <textarea id="note-content" rows="5" placeholder="分析题意，描述算法思路…"></textarea>
  </div>
  <div class="form-group">
    <label>C++ 代码</label>
    <textarea id="note-code" class="code-input" rows="8" placeholder="#include &lt;bits/stdc++.h&gt;&#10;using namespace std;"></textarea>
  </div>
  <div class="form-group">
    <label>反思与总结</label>
    <textarea id="note-reflection" rows="3" placeholder="收获、易错点…"></textarea>
  </div>
  <div class="form-group">
    <label>配图 <span style="font-size:11px;color:var(--text3);font-weight:400">（可上传多张，支持PNG/JPG，每张≤2MB）</span></label>
    <div class="note-img-upload-area" onclick="document.getElementById('note-img-input').click()">
      <input type="file" id="note-img-input" accept="image/*" multiple style="display:none" onchange="handleNoteImgSelect(this)">
      <span style="font-family:var(--mono);font-size:12px;color:var(--text3)">📎 点击选择图片</span>
    </div>
    <div class="note-img-preview-list" id="note-img-preview-list"></div>
  </div>
  <div id="note-error" class="form-error"></div>
  <div class="modal-footer" style="justify-content:flex-end;padding-top:12px">
    <button class="btn btn-ghost" onclick="closeNoteDrawer()">取消</button>
    <button class="btn btn-primary" onclick="submitNote()">发布题解</button>
  </div>
</div>

<!-- LUOGU BATCH IMPORT MODAL -->
<div class="modal-overlay" id="luogu-import-modal">
  <div class="modal" style="width:620px;max-width:98vw">
    <h2>📥 洛谷题目导入</h2>
    <p style="font-size:13px;color:var(--text2);margin-bottom:14px;line-height:1.7">
      输入题号导入，或一键预置经典题目集。系统会尝试自动获取题目名称。
    </p>

    <!-- 预置题目集 -->
    <div style="margin-bottom:16px">
      <div style="font-size:12px;color:var(--text3);letter-spacing:0.1em;margin-bottom:8px">📚 一键预置题目集</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        <button class="btn btn-outline btn-sm" onclick="presetProblems('入门')">入门题单 (20题)</button>
        <button class="btn btn-outline btn-sm" onclick="presetProblems('普及')">普及题单 (20题)</button>
        <button class="btn btn-outline btn-sm" onclick="presetProblems('提高')">提高题单 (20题)</button>
        <button class="btn btn-outline btn-sm" onclick="presetProblems('dp')">DP 专题 (15题)</button>
        <button class="btn btn-outline btn-sm" onclick="presetProblems('graph')">图论专题 (15题)</button>
        <button class="btn btn-outline btn-sm" onclick="presetProblems('ds')">数据结构 (15题)</button>
      </div>
    </div>

    <div class="form-group">
      <label>题号列表（也可手动输入，支持空格/换行/逗号）</label>
      <textarea id="luogu-import-ids" rows="5" placeholder="P1001&#10;P1002&#10;P3376&#10;P2763&#10;..."></textarea>
    </div>
    <div id="luogu-import-preview" style="display:none;margin-bottom:12px;max-height:120px;overflow-y:auto;padding:8px 12px;background:rgba(45,232,176,0.05);border:1px solid rgba(45,232,176,0.15);border-radius:8px;font-size:12px;color:var(--text2);font-family:var(--mono)"></div>
    <div class="form-row">
      <div class="form-group">
        <label>统一难度（可选）</label>
        <select id="luogu-import-diff">
          <option value="">不设置</option>
          <option value="入门">入门</option>
          <option value="普及">普及</option>
          <option value="提高">提高</option>
          <option value="省选">省选</option>
        </select>
      </div>
      <div class="form-group">
        <label>统一知识点（可选）</label>
        <input type="text" id="luogu-import-topic" placeholder="例：图论">
      </div>
    </div>
    <div id="luogu-fetch-status" style="display:none;padding:10px 14px;background:rgba(108,142,245,0.06);border:1px solid rgba(108,142,245,0.15);border-radius:8px;font-size:12px;color:var(--accent);margin-bottom:12px">
      🔄 正在获取题目名称…
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('luogu-import-modal')">取消</button>
      <button class="btn btn-primary" id="luogu-import-btn" onclick="submitLuoguImport()">导入题目</button>
    </div>
  </div>
</div>

<!-- SETTINGS MODAL -->
<div class="modal-overlay" id="settings-modal">
  <div class="modal" style="width:480px;max-width:98vw">
    <div class="modal-tabs" style="margin-bottom:18px">
      <button class="modal-tab active" onclick="switchSettingsTab('avatar')">个人资料</button>
      <button class="modal-tab" onclick="switchSettingsTab('password')">修改密码</button>
    </div>
    <button class="modal-close" onclick="closeModal('settings-modal')" style="position:absolute;top:16px;right:16px">✕</button>

    <div id="settings-avatar-tab">
      <!-- 头像上传 -->
      <div class="form-group">
        <label>头像</label>
        <div class="avatar-upload-wrap">
          <div class="avatar-upload-preview" id="avatar-preview-wrap">
            <div id="avatar-preview-inner"></div>
          </div>
          <div class="avatar-upload-right">
            <label class="btn btn-outline btn-sm avatar-file-label" for="set-avatar-file">
              📷 选择图片
            </label>
            <input type="file" id="set-avatar-file" accept="image/*" style="display:none" onchange="previewAvatar(this)">
            <div style="font-size:11px;color:var(--text3);margin-top:6px">JPG/PNG，建议正方形，≤ 2MB</div>
            <div id="avatar-upload-progress" style="display:none;margin-top:8px">
              <div class="avatar-upload-bar"><div id="avatar-upload-fill"></div></div>
              <div id="avatar-upload-label" style="font-size:11px;color:var(--text3);margin-top:4px">上传中…</div>
            </div>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label>座右铭 <span style="font-size:11px;color:var(--text3);font-weight:400">（展示在个人主页）</span></label>
        <input type="text" id="set-motto" placeholder="一句话激励自己…" maxlength="50">
        <div style="text-align:right;font-size:11px;color:var(--text3);margin-top:4px"><span id="motto-count">0</span>/50</div>
      </div>
      <div class="form-group">
        <label>个人简介</label>
        <textarea id="set-bio" rows="3" placeholder="介绍一下自己…"></textarea>
      </div>
      <div class="form-group">
        <label>洛谷 UID <span style="font-size:11px;color:var(--text3);font-weight:400">（填写后雷达图将使用洛谷通过题目）</span></label>
        <input type="text" id="set-luogu-uid" placeholder="如：123456">
      </div>
      <div class="form-group" id="set-group-wrap">
        <label>训练组</label>
        <select id="set-group">
          <option value="">请选择</option>
          <option value="1">L1</option>
          <option value="2">L2</option>
          <option value="3">L3</option>
          <option value="4">L4</option>
          <option value="5">L5</option>
          <option value="6">L6</option>
          <option value="7">Oth</option>
        </select>
      </div>
      <div id="settings-avatar-error" class="form-error"></div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeModal('settings-modal')">取消</button>
        <button class="btn btn-primary" onclick="saveSettings()">保存</button>
      </div>
    </div>

    <div id="settings-password-tab" style="display:none">
      <div class="form-group">
        <label>新密码</label>
        <input type="password" id="set-newpw" placeholder="至少6位">
      </div>
      <div class="form-group">
        <label>确认新密码</label>
        <input type="password" id="set-newpw2" placeholder="再输一次">
      </div>
      <div id="settings-pw-error" class="form-error"></div>
      <div id="settings-pw-success" style="color:var(--accent2);font-size:13px;margin-top:8px"></div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeModal('settings-modal')">取消</button>
        <button class="btn btn-primary" onclick="savePassword()">修改密码</button>
      </div>
    </div>
  </div>
</div>

